// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("VIEWER") // ADMIN, VIEWER
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id               String      @id @default(cuid())
  name             String
  category         String?
  subcategory      String?
  novedad          String?
  description      String?
  imageUrl         String?
  totalQuantity    Int         @default(0)
  priceUnit        Float       @default(0.0)
  priceReplacement Float       @default(0.0)
  quantityDamaged  Int         @default(0)

  eventItems       EventItem[]
  inventoryLogs    InventoryLog[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Event {
  id        String      @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String      @default("SIN_CONFIRMAR") // SIN_CONFIRMAR, RESERVADO, DESPACHADO, COMPLETADO, CANCELADO
  notes     String?
  deposit   Float       @default(0.0)
  transport Float       @default(0.0)
  discount  Float       @default(0.0)
  items     EventItem[]
  history   EventHistory[]
  clientId  String?
  client    Client?     @relation(fields: [clientId], references: [id])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Client {
  id           String   @id @default(cuid())
  name         String
  document     String?  // CC or NIT
  email        String?
  phone        String?
  department   String?
  city         String?
  neighborhood String?
  address      String?
  notes        String?
  events       Event[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EventItem {
  id              String    @id @default(cuid())
  eventId         String
  event           Event     @relation(fields: [eventId], references: [id])
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  quantity        Int
  returnedGood    Int       @default(0)
  returnedDamaged Int       @default(0)
  damagePaid      Boolean   @default(false)
  damageRestored  Boolean   @default(false)
  restoredAt      DateTime?
  
  @@unique([eventId, productId])
}

model InventoryLog {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  change      Int      // Positive for add, negative for sub
  newTotal    Int      // Snapshot of total after change
  type        String   // PURCHASE, ADJUSTMENT, RETURN, EVENT_USAGE
  receivedBy  String?
  verifiedBy  String?
  notes       String?
  createdAt   DateTime @default(now())
}

model EventHistory {
  id             String   @id @default(cuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  previousStatus String?
  newStatus      String
  changedBy      String?  // User email or identifier
  reason         String?  // Optional notes for the change
  createdAt      DateTime @default(now())
}
